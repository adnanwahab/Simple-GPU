{
  "name": "simple-gpu",
  "version": "0.41.0",
  "description": "simple-gpu is a fast functional WebGPU framework.",
  "scripts": {
    "build:html": "node ./src/build-html.mjs",
    "build:js": "esbuild --bundle ./src/demos/* --outdir=dist/",
    "build": "npm run build:html && npm run build:js",
    "dev": "vite",
    "build-module": "rm -rf dist && rollup -c ",
    "watch:js": "esbuild --sourcemap --bundle ./src/demos/* --outdir=dist/ --watch --servedir=dist",
    "watch": "npm run build:html && npm run watch:js",
    "test": "TZ=America/Los_Angeles mocha 'test/**/*-test.js' && eslint src test"
  },
  "files": [
    "dist/**/*.js",
    "lib/**/*.js"
  ],
  "module": "lib/index.js",
  "main": "lib/index.js",
  "jsdelivr": "dist/simple-gpu.min.js",
  "exports": {
    "umd": "./dist/simple-gpu.min.js",
    "default": "./src/index.js"
  },
  "devDependencies": {
    "@mediapipe/face_detection": "~0.4.0",
    "@rollup/plugin-json": "6",
    "@rollup/plugin-node-resolve": "15",
    "@types/node": "^18.11.18",
    "@webgpu/types": "^0.1.24",
    "d3": "^7.8.2",
    "d3-geo": "^3.1.0",
    "esbuild": "^0.17.0",
    "getusermedia": "2.0.1",
    "gl-matrix": "^3.4.3",
    "mocha": "9",
    "mouse-change": "latest",
    "mouse-wheel": "latest",
    "rollup": "3",
    "stanford-dragon": "^1.1.1",
    "three": "0.149.0",
    "ts-node": "^10.9.1",
    "typescript": "^4.4.4",
    "vite": "^2.6.13"
  },
  "dependencies": {
    "@loaders.gl/core": "^3.3.1",
    "@loaders.gl/gltf": "^3.3.1",
    "bunny": "^1.0.1",
    "csv-parser": "^3.0.0",
    "loaders.gl": "^0.3.5",
    "three-collada-loader": "^0.0.1",
    "three-fbx-loader": "^1.0.3",
    "three-gltf-loader": "^1.111.0",
    "web-audio-beat-detector": "^8.1.43"
  },
  "keywords": [
    "webgpu",
    "stackgl",
    "regl",
    "gl",
    "graphics",
    "computer graphics",
    "opengl",
    "wgsl",
    "data",
    "flow",
    "reactive",
    "functional"
  ],
  "license": "BSD",
  "bugs": {
    "url": "https://github.com/adnanwahab/simple-webgpu/issues"
  },
  "homepage": "https://simple-webgpu.com"
}
