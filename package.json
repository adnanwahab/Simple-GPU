{
  "name": "simple-gpu",
  "version": "0.41.0",
  "description": "simple-gpu is a fast functional WebGPU framework.",
  "scripts": {
    "build": "vite build",
    "start": "vite",
    "dev": "vite",
    "test": "TZ=America/Los_Angeles mocha 'test/**/*-test.js' && eslint src test",
    "preview": "vite preview",
    "deploy": "surge dist kodiak-awahab.surge.sh",
    "build:client": "vite build --outDir dist/client",
    "build:server": "vite build --outDir dist/server --ssr src/entry-server.js",
    "server": "node server",
    "tesla": "surge dist tesla-awahab.surge.sh"
  },
  "files": [
    "dist/**/*.js",
    "lib/**/*.js"
  ],
  "module": "lib/index.js",
  "main": "lib/index.js",
  "jsdelivr": "dist/simple-gpu.min.js",
  "exports": {
    "umd": "./dist/simple-gpu.min.js",
    "default": "./src/index.js"
  },
  "devDependencies": {
    "@flydotio/dockerfile": "^0.5.0",
    "@rollup/plugin-json": "6",
    "@rollup/plugin-node-resolve": "15",
    "@vitejs/plugin-react": "4.1",
    "d3": "^7.1.1",
    "gl-matrix": "^3.4.3",
    "mocha": "9",
    "rollup": "3",
    "stanford-dragon": "^1.1.1",
    "typescript": "^4.4.4",
    "vite": "^4.5.0",
    "vite-plugin-glsl": "^1.1.2",
    "vitepress": "^1.0.0-rc.33",
    "vue": "^3.3.13",
    "wgpu-matrix": "^2.5.1"
  },
  "dependencies": {
    "@deck.gl/core": "^8.9.33",
    "@deck.gl/layers": "^8.9.33",
    "@deck.gl/react": "^8.9.33",
    "@loaders.gl/las": "^4.0.4",
    "apache-arrow": "^14.0.2",
    "body-parser": "^1.20.2",
    "express": "^4.18.2",
    "glob": "^10.3.10",
    "lil-gui": "^0.19.0",
    "react": "18.2",
    "react-dom": "18.2",
    "three": "^0.158.0"
  },
  "keywords": [
    "webgpu",
    "stackgl",
    "regl",
    "gl",
    "graphics",
    "computer graphics",
    "opengl",
    "wgsl",
    "data",
    "flow",
    "reactive",
    "functional"
  ],
  "license": "BSD",
  "bugs": {
    "url": "https://github.com/adnanwahab/simple-webgpu/issues"
  },
  "homepage": "https://simple-webgpu.com",
  "dockerfile": {
    "packages": {
      "deploy": [
        "dnsutils"
      ]
    }
  },
  "directories": {
    "lib": "lib"
  },
  "author": ""
}
